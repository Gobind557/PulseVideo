# Copy to .env at repo root for local development

NODE_ENV=development

# API (backend)
PORT=4000
PUBLIC_API_URL=http://localhost:4000
# Local: mongodb://127.0.0.1:27017/pulse  |  Atlas: mongodb+srv://user:pass@cluster.../pulse?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/pulse
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace-with-a-long-random-secret-in-production
# JWT_REFRESH_SECRET=another-long-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
CORS_ORIGIN=http://localhost:5173

# Local file storage (relative to backend working dir or absolute)
UPLOAD_DIR=uploads
STORAGE_DRIVER=local

# S3-compatible (optional; required for STORAGE_DRIVER=s3 presigned flow)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=pulse-videos
# S3_PUBLIC_BASE_URL=https://your-bucket.s3.amazonaws.com

# Frontend (Vite) — optional override; default is proxy in dev
# VITE_API_URL=http://localhost:4000
# VITE_WS_URL=http://localhost:4000

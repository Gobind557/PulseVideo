{
  "name": "pulse-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/workers/video.worker.ts",
    "dev:all": "concurrently -n api,worker -c cyan,magenta \"npm:dev\" \"npm:worker\"",
    "seed:demo": "tsx src/scripts/seed-demo.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:worker": "node dist/workers/video.worker.js",
    "start:all": "concurrently -n api,worker -c cyan,magenta \"npm:start\" \"npm:start:worker\"",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.731.0",
    "@aws-sdk/s3-request-presigner": "^3.731.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "concurrently": "^9.2.0",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
